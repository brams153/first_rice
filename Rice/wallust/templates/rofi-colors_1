* {
    background: {{background}};
    foreground: {{foreground}};
    color1: {{color1}};
    color4: {{color4}};

    /* Tu launcher ahora solo usará esta paleta reducida */
    bg:  @background;
    fg:  @foreground;
    ac:  @color4;      /* Cambiado a color4 para que combine con Polybar */
    bar: @foreground;
    bga: @color1;
    al:  #00000000;
}
