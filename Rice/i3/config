# --- ARRANQUE ORDENADO (Wallust -> Feh -> Picom -> Polybar) ---
exec_always --no-startup-id bash -c ' \
    WALLPAPER=$(find ~/Pictures/Fondos -type f | shuf -n 1); \
    feh --bg-fill "$WALLPAPER" && \
    wallust run "$WALLPAPER"; \
    killall picom; sleep 1; \
    picom --config ~/.config/picom/picom.conf -b; \
    ~/.config/polybar/material/launch.sh \
'

exec --no-startup-id nm-applet




#exec_always --no-startup-id feh --bg-fill --randomize ~/Pictures/Fondos/*

exec --no-startup-id xsettingsd &
#exec_always --no-startup-id picom --config ~/.config/picom/picom.conf -b
exec --no-startup-id xss-lock --transfer-sleep-lock -- i3lock --nofork
# portapales
exec --no-startup-id copyq
#for_window [class="copyq"] floating enable, resize set 50 #ppt 50 ppt, move position 50 ppt 50 ppt
for_window [class="copyq"]floating enable, resize set 30 ppt 30 ppt, move position 70 ppt 70 ppt
#Portapales
bindsym $mod+Shift+v exec --no-startup-id copyq toggle

# Idiomas
# Cambiar a teclado Inglés (US)
bindsym $mod+Shift+u exec "setxkbmap us"

# Cambiar a teclado Español (con Ñ)
bindsym $mod+Shift+i exec "setxkbmap es"
exec --no-startup-id setxkbmap us

# --- ATAJOS MULTIMEDIA (Recuperados del config anterior) ---
set $refresh_i3status killall -SIGUSR1 i3status
bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +10% && $refresh_i3status
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -10% && $refresh_i3status
bindsym XF86AudioMute exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle && $refresh_i3status
bindsym XF86AudioMicMute exec --no-startup-id pactl set-source-mute @DEFAULT_SOURCE@ toggle && $refresh_i3status

# --- LANZADORES Y TERMINAL ---
# Cambio de Kitty a Alacritty
bindsym $mod+Return exec kitty

# Lanzador Rofi (Estilo actual)
#bindsym $mod+d exec rofi -lines 12 -padding 18 -width 60 -location 0 -show drun -sidebar-mode -columns 
bindsym $mod+d exec --no-startup-id ~/.config/polybar/material/scripts/launcher.sh

# Captura de pantalla
bindsym $mod+Shift+p exec maim -u ~/$(date +%s).png

# Activar/Desactivar Caffeine 
bindsym $mod+Shift+x exec --no-startup-id /home/brams/.config/i3/scripts/caffeine.sh --toggle && polybar-msg cmd restart
# --- NAVEGACIÓN Y VENTANAS ---
floating_modifier $mod
tiling_drag modifier titlebar

bindsym $mod+Shift+q kill

# Foco (Teclas jkl;)
bindsym $mod+j focus left
bindsym $mod+k focus down
bindsym $mod+l focus up
bindsym $mod+semicolon focus right
# Flechas
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# Mover ventanas
bindsym $mod+Shift+j move left
bindsym $mod+Shift+k move down
bindsym $mod+Shift+l move up
bindsym $mod+Shift+semicolon move right

# Splits y Layouts
bindsym $mod+h split h
bindsym $mod+v split v
bindsym $mod+f fullscreen toggle
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split
bindsym $mod+Shift+space floating toggle
bindsym $mod+space focus mode_toggle
bindsym $mod+a focus parent

# Relativas 
# Esquina Superior Izquierda
bindsym Mod4+Shift+Left  floating enable; resize set 50 ppt 50 ppt; move position 0 px 0 px

# Esquina Superior Derecha
bindsym Mod4+Shift+Up    floating enable; resize set 50 ppt 50 ppt; move position 50 ppt 0 px

# Esquina Inferior Izquierda
bindsym Mod4+Shift+Down  floating enable; resize set 50 ppt 50 ppt; move position 0 px 50 ppt

# Esquina Inferior Derecha
bindsym Mod4+Shift+Right floating enable; resize set 50 ppt 50 ppt; move position 50 ppt 50 ppt
